# LTX-2.3 Workflows .gitignore
# Ignore generated media (videos/images are huge and better stored elsewhere)
*.mp4
*.mov
*.avi
*.webm
*.mkv
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp3
*.wav
*.flac

# ComfyUI temp / output folders
ComfyUI/output/
ComfyUI/temp/
ComfyUI/input/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE / OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets / keys (never commit these)
.env
*.key
secrets/
graydient_token.txt

# Large model files (don't commit these)
*.safetensors
*.ckpt
*.pt
*.pth
models/
loras/

# Logs and temp folders
*.log
logs/
temp_*/
test_*/
scratch/